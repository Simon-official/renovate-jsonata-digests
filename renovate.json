{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "toml",
      "managerFilePatterns": [
        "versions.toml"
      ],
      "matchStrings": [
        "*.{ 'depName': image, 'currentValue': version, 'currentDigest': digest, 'datasource': 'docker'}" 
      ]
    }
  ]
}

